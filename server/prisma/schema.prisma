generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  passwordHash  String

  streak        Int      @default(0)
  longestStreak Int      @default(0)

  memorizedJuzCount Int    @default(0)
  memorizedJuzList  String @default("[]")
  currentJuz        Int?
  currentSurah      Int?
  currentAyah       Int?

  averageSabaqPages     Float @default(0.5)
  averageSabaqParaPages Float @default(3)
  averageRevisionJuz    Float @default(0.25)

  lastEntryDate DateTime?

  entries       DailyEntry[]
}

model DailyEntry {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime @default(now())

  sabaq     String
  sabaqPara String
  manzil    String
  sabaqSaved     Boolean @default(false)
  sabaqParaSaved Boolean @default(false)
  manzilSaved    Boolean @default(false)
  notes     String?

  user      User @relation(fields: [userId], references: [id])
}
